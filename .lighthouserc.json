{
  "ci": {
    "collect": {
      "staticDistDir": "./public",
      "numberOfRuns": 1,
      "url": [
        "http://localhost/",
        "http://localhost/start/",
        "http://localhost/posts/",
        "http://localhost/tags/",
        "http://localhost/posts/azure-stack-hci-23h2-installation-and-setup-guide/"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.8
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports"
    }
  }
}
